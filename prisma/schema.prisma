generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id                String             @id @default(cuid())
  ownerId           String
  name              String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  currentManifestId String?
  owner             User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  manifests         Manifest[]
  fileIndexes       WorkspaceFileIndex[]
  agentSessions     AgentSession[]
  buildCaches       BuildCacheEntry[]
  checkpoints       Checkpoint[]
  secrets           Secret[]

  @@map("projects")
}

model Manifest {
  id               String       @id @default(cuid())
  projectId        String
  version          Int
  manifestJson     Json
  createdAt        DateTime     @default(now())
  parentManifestId String?
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent           Manifest?    @relation("ManifestHistory", fields: [parentManifestId], references: [id])
  children         Manifest[]   @relation("ManifestHistory")
  checkpoints      Checkpoint[]

  @@map("manifests")
}

model Chunk {
  id          String   @id @default(cuid())
  hash        String   @unique
  size        Int
  storagePath String
  refCount    Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("chunks")
}

model WorkspaceFileIndex {
  id         String            @id @default(cuid())
  projectId  String
  path       String
  astJson    Json?
  symbols    Json?
  lastEdited DateTime
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  embeddings VectorEmbedding[]

  @@unique([projectId, path])
  @@map("workspace_file_indexes")
}

model VectorEmbedding {
  id             String             @id @default(cuid())
  fileIndexId    String
  embedding      Unsupported("vector(1536)")?
  contentSnippet String             @db.Text
  fileIndex      WorkspaceFileIndex @relation(fields: [fileIndexId], references: [id], onDelete: Cascade)

  @@map("vector_embeddings")
}

model AgentSession {
  id            String      @id @default(cuid())
  projectId     String
  status        String
  startTime     DateTime    @default(now())
  endTime       DateTime?
  currentTaskId String?
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks         AgentTask[]

  @@map("agent_sessions")
}

model AgentTask {
  id              String            @id @default(cuid())
  sessionId       String
  agentType       String
  input           String            @db.Text
  outputSummary   String?           @db.Text
  status          String
  retries         Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  session         AgentSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  verificationRun VerificationRun?

  @@map("agent_tasks")
}

model BuildCacheEntry {
  id            String   @id @default(cuid())
  projectId     String
  configHash    String
  envJson       Json
  storePathsJson Json
  createdAt     DateTime @default(now())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, configHash])
  @@map("build_cache_entries")
}

model VerificationRun {
  id              String    @id @default(cuid())
  taskId          String    @unique
  videoPath       String?
  screenshotsJson Json?
  result          String
  patchApplied    Boolean   @default(false)
  createdAt       DateTime  @default(now())
  task            AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("verification_runs")
}

model Checkpoint {
  id          String   @id @default(cuid())
  projectId   String
  manifestId  String
  reason      String
  timestamp   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  manifest    Manifest @relation(fields: [manifestId], references: [id], onDelete: Cascade)

  @@map("checkpoints")
}

model Secret {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  encryptedValue String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@map("secrets")
}
